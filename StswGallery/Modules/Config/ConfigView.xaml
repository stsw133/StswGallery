<UserControl x:Class="StswGallery.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:se="clr-namespace:StswExpress.Wpf;assembly=StswExpress.Wpf"
             xmlns:local="clr-namespace:StswGallery"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance local:ConfigContext}"
             MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type se:StswContentDialog}}, Converter={x:Static se:StswCalculateConverter.Instance}, ConverterParameter=*0.8}"
             MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type se:StswContentDialog}}, Converter={x:Static se:StswCalculateConverter.Instance}, ConverterParameter=*0.95}">

    <se:StswGroupBox Padding="0">
        <se:StswGroupBox.Header>
            <se:StswLabel Content="Config" IconData="{x:Static se:StswIcons.Cog}" Margin="3"/>
        </se:StswGroupBox.Header>

        <DockPanel>
            <!-- button panel -->
            <UniformGrid DockPanel.Dock="Bottom" HorizontalAlignment="Center" Margin="5" Rows="1">
                <se:StswButton Command="{Binding SaveCommand}" Margin="3" Padding="10 3">
                    <se:StswLabel Content="Save" IconData="{x:Static se:StswIcons.ContentSave}" IconFill="{DynamicResource StswColor.Modify}"/>
                </se:StswButton>
                <se:StswButton Command="{Binding CancelCommand}" Margin="3" Padding="10 3">
                    <se:StswLabel Content="Cancel" IconData="{x:Static se:StswIcons.Cancel}" IconFill="{DynamicResource StswColor.Negative}"/>
                </se:StswButton>
            </UniformGrid>
            <se:StswSeparator DockPanel.Dock="Bottom" BorderThickness="1"/>

            <se:StswScrollView>
                <StackPanel>
                    <se:StswCheckBox Margin="6 10 6 0"
                                     Content="Allow image upscaling"
                                     IsChecked="{Binding Settings.UseDefaultStretchDirection, Mode=TwoWay}"
                                     ToolTip="When enabled, images smaller than the viewer are enlarged to fit. Large images are always scaled down when needed."/>

                    <se:StswSeparator BorderThickness="1"/>

                    <!-- keys 0-9 settings -->
                    <se:StswLabel DockPanel.Dock="Top"
                                  Content="NUMBER SHORTCUTS"
                                  FontSize="10"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Margin="0 10 0 0"/>

                    <Grid Margin="6 3 6 0" se:StswGrid.ColumnDefinitions="40,150,320,260,130,140,90">
                        <se:StswLabel Grid.Column="0" Content="#" FontSize="10" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                        <se:StswLabel Grid.Column="1" Content="Type" FontSize="10" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                        <se:StswLabel Grid.Column="2" Content="Target path" FontSize="10" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                        <se:StswLabel Grid.Column="3" Content="Arguments" FontSize="10" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                        <se:StswLabel Grid.Column="4" Content="Conflict" FontSize="10" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                        <se:StswLabel Grid.Column="5" Content="After action" FontSize="10" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                        <se:StswLabel Grid.Column="6" Content="Create dir" FontSize="10" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                    </Grid>

                    <ItemsControl DockPanel.Dock="Top" Margin="3" ItemsSource="{Binding Settings.Shortcuts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="3" se:StswGrid.ColumnDefinitions="40,150,320,260,130,140,90">
                                    <se:StswLabel Grid.Column="0"
                                                  Content="{Binding Number}"
                                                  HorizontalContentAlignment="Right"
                                                  Margin="3"/>
                                    <se:StswComboBox Grid.Column="1"
                                                     DisplayMemberPath="Display"
                                                     ItemsSource="{Binding DataContext.ShortcutTypes, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneTime}"
                                                     Margin="3"
                                                     SelectedValue="{Binding Type, Mode=TwoWay}"
                                                     SelectedValuePath="Value"
                                                     ToolTip="Operation assigned to this number shortcut."/>
                                    <se:StswTextBox Grid.Column="2"
                                                    Margin="3"
                                                    Text="{Binding TargetPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    ToolTip="Folder path for Move/Copy, executable path for Open with."/>
                                    <se:StswTextBox Grid.Column="3"
                                                    Margin="3"
                                                    Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    ToolTip="Optional Open with argument template. Supported tokens: {file}, {directory}, {name}, {nameWithoutExtension}, {extension}. Empty means &quot;{file}&quot;."/>
                                    <se:StswComboBox Grid.Column="4"
                                                     DisplayMemberPath="Display"
                                                     ItemsSource="{Binding DataContext.FileConflictModes, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneTime}"
                                                     Margin="3"
                                                     SelectedValue="{Binding ConflictMode, Mode=TwoWay}"
                                                     SelectedValuePath="Value"
                                                     ToolTip="What to do when the target file already exists."/>
                                    <se:StswComboBox Grid.Column="5"
                                                     DisplayMemberPath="Display"
                                                     ItemsSource="{Binding DataContext.AfterShortcutActions, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneTime}"
                                                     Margin="3"
                                                     SelectedValue="{Binding AfterAction, Mode=TwoWay}"
                                                     SelectedValuePath="Value"
                                                     ToolTip="What to select after a shortcut operation completes."/>
                                    <se:StswCheckBox Grid.Column="6"
                                                     HorizontalAlignment="Center"
                                                     IsChecked="{Binding CreateTargetDirectory, Mode=TwoWay}"
                                                     Margin="3"
                                                     ToolTip="Create the target directory automatically when it does not exist."/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <se:StswSeparator DockPanel.Dock="Top" BorderThickness="1"/>

                    <!-- action key settings -->
                    <se:StswLabel DockPanel.Dock="Top"
                                  Content="APPLICATION SHORTCUTS"
                                  FontSize="10"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Margin="0 10 0 0"/>
                    <ItemsControl DockPanel.Dock="Top" Margin="3" ItemsSource="{Binding Settings.ActionKeys}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="3" se:StswGrid.ColumnDefinitions="175,500">
                                    <se:StswLabel Grid.Column="0"
                                                  Content="{Binding Action, Converter={x:Static local:ActionKeyTypeDescriptionConverter.Instance}}"
                                                  Margin="3"
                                                  HorizontalContentAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    <se:StswComboBox Grid.Column="1"
                                                     ItemsSource="{Binding DataContext.AvailableKeys, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneTime}"
                                                     Margin="3"
                                                     SelectedItem="{Binding Key, Mode=TwoWay}"
                                                     ToolTip="Keyboard shortcut for this application action."/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </se:StswScrollView>
        </DockPanel>
    </se:StswGroupBox>
</UserControl>
